{
  "name": "orangehrm-playwright-framework",
  "version": "1.0.0",
  "description": "Enterprise Playwright automation framework for OrangeHRM HRMS",
  "author": "Arun N",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",

    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit",

    "test:login": "playwright test tests/e2e/login.spec.js",
    "test:dashboard": "playwright test tests/e2e/dashboard.spec.js",
    "test:pim": "playwright test tests/e2e/employee-management.spec.js",
    "test:leave": "playwright test tests/e2e/leave-management.spec.js",
    "test:recruitment": "playwright test tests/e2e/recruitment.spec.js",
    "test:admin": "playwright test tests/e2e/admin-user-management.spec.js",
    "test:search": "playwright test tests/e2e/search-filters.spec.js",
    "test:api": "playwright test tests/api/",

    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @critical",
    "test:sanity": "playwright test --grep @sanity",

    "report:html": "playwright show-report playwright-report",
    "report:allure:generate": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "report:allure:serve": "allure serve allure-results",

    "clean": "rm -rf allure-results allure-report test-results",
    "test:ci": "playwright test --reporter=list,allure-playwright"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.30.0",
    "dotenv": "^16.4.5",
    "@faker-js/faker": "^8.4.1"
  }
}